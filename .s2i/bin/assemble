#!/usr/bin/env bash
set -euo pipefail

APP_DIR="${APP_DIR:-/var/www/html}"
ARTIFACTS_DIR="${ARTIFACTS_DIR:-/tmp/artifacts}"

cd "$APP_DIR"

export COMPOSER_ALLOW_SUPERUSER=1

echo "[s2i:assemble] Restoring cached artifacts when available"
if [[ -f "$ARTIFACTS_DIR/vendor.tar" ]]; then
  tar -C "$APP_DIR" -xf "$ARTIFACTS_DIR/vendor.tar"
fi

if [[ -f "$ARTIFACTS_DIR/node_modules.tar" ]]; then
  tar -C "$APP_DIR" -xf "$ARTIFACTS_DIR/node_modules.tar"
fi

echo "[s2i:assemble] Ensuring writable runtime paths"
mkdir -p storage/framework/cache/data storage/framework/sessions storage/framework/views storage/logs database
touch database/database.sqlite

echo "[s2i:assemble] Installing PHP dependencies"
composer install --no-interaction --no-dev --optimize-autoloader --prefer-dist

echo "[s2i:assemble] Preparing environment file"
if [[ ! -f .env && -f .env.example ]]; then
  cp .env.example .env
fi

echo "[s2i:assemble] Installing Node dependencies"
npm ci --no-audit --no-fund

echo "[s2i:assemble] Building frontend assets"
npm run build

echo "[s2i:assemble] Clearing Laravel caches"
php artisan config:clear --no-interaction
php artisan route:clear --no-interaction
php artisan view:clear --no-interaction
php artisan cache:clear --no-interaction

echo "[s2i:assemble] Completed"