#!/usr/bin/env bash
set -euo pipefail

APP_DIR="${APP_DIR:-/opt/app-root/src}"
PORT="${PORT:-8080}"
RUN_MIGRATIONS_ON_STARTUP="${RUN_MIGRATIONS_ON_STARTUP:-false}"

cd "$APP_DIR"

# Optionally run migrations on startup.
# Prefer a separate Job in OpenShift for better rollout control.
if [[ "$RUN_MIGRATIONS_ON_STARTUP" == "true" ]]; then
  echo "[s2i:run] Running database migrations..."
  php artisan migrate --force
else
  echo "[s2i:run] Skipping startup migrations (RUN_MIGRATIONS_ON_STARTUP=false)"
fi


echo "[s2i:run] Starting application runtime"

if [[ -x /usr/libexec/s2i/run ]]; then
  exec /usr/libexec/s2i/run
fi

if command -v php >/dev/null 2>&1 && [[ -f artisan ]]; then
  echo "[s2i:run] Builder run script not found, using Laravel fallback"
  exec php artisan serve --host=0.0.0.0 --port="$PORT"
fi

echo "[s2i:run] No known runtime entrypoint found" >&2
exit 1